{
  "version": 1,
  "session": "relaymux-mock",
  "stateDir": "/tmp/relaymux-mock/state",
  "tmux": {
    "sessionMode": "shared",
    "sessionPrefix": "rmx"
  },
  "integrations": {},
  "daemon": {
    "enabled": true,
    "host": "127.0.0.1",
    "port": 47762,
    "tokenFile": "/tmp/relaymux-mock/webhook-token",
    "maxBodyBytes": 65536,
    "launchAgentLabel": "com.relaymux.mock",
    "launchMode": "direct",
    "supervisorPollMs": 15000,
    "logDir": "/tmp/relaymux-mock/logs"
  },
  "orchestrator": {
    "cwd": "/tmp",
    "command": ["sh", "-lc", "printf 'mock orchestrator reply\\n'"],
    "promptMode": "none",
    "timeoutMs": 5000
  },
  "agents": {
    "custom": {
      "command": ["sh", "-lc", "printf 'mock subagent running: %s\\n' \"$RELAYMUX_PROMPT\""],
      "promptMode": "env"
    }
  }
}
