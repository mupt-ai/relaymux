{
  "name": "relaymux",
  "version": "0.1.0",
  "description": "Coordinate CLI agents across local tmux, local background, and cloud-sandbox execution backends.",
  "type": "module",
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/bin/relaymux.js', 0o755)\"",
    "lint": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "validate": "npm run lint && npm test && npm run build"
  },
  "keywords": [
    "agents",
    "tmux",
    "webhook",
    "telegram",
    "imessage",
    "orchestration",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mupt-ai/relaymux.git"
  },
  "bugs": {
    "url": "https://github.com/mupt-ai/relaymux/issues"
  },
  "homepage": "https://github.com/mupt-ai/relaymux#readme",
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
